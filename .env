# =====================================================================
# FRAUDSHIELD FRONTEND ENVIRONMENT VARIABLES
# =====================================================================

# 1. THE API BRIDGE (Crucial)
# This is where your React app will send all requests.
# It points exactly to your Flask backend.
VITE_API_BASE_URL=http://127.0.0.1:5000

# 2. BRANDING & UI SETTINGS
# Used to dynamically display the app name in the dashboard headers.
VITE_APP_NAME="FraudShield Platform"
VITE_APP_VERSION="1.0.0"

# 3. DASHBOARD CONFIGURATIONS
# How many transactions should show in the table before pagination?
VITE_MAX_TABLE_ROWS=15

# (Optional) You can change this to 'false' later when you go to production
VITE_ENABLE_DEBUG_MODE=true